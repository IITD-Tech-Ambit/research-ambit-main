MONGO_URI="your-mongo-connection-string"
JWT_SECRET="your-jwt-secret"
CLOUDINARY_CLOUD_NAME="devcluster"
CLOUDINARY_API_KEY="266666666666666"
CLOUDINARY_API_SECRET="devcluster"

# Atlas — all KG/Atlas data is served from MongoDB (published by
# knowledge-graph/pipeline/build_kg.py). KG_DATA_DIR only affects that offline
# pipeline now; the runtime no longer reads the filesystem.
# KG_DATA_DIR="./data/knowledge-graph"
# KG_ACTIVE_TTL_MS=30000   # how long the resolved active build version is cached
# KG_TILE_LRU_MAX=512      # in-process hot cache size for binary atlas tiles

# Redis (used for KG API response caching)
# REDIS_URL="redis://localhost:6379"
# KG_CACHE_TTL_S=10800

# gRPC (directory.v1 east-west mesh listener, fronted by Envoy)
# GRPC_ENABLED=true                 # set false to run REST-only
# GRPC_BIND_ADDRESS=0.0.0.0:50055   # frozen by the Envoy cluster contract
# PROTO_DIR=./protos                # committed proto copy (seeded by protos/sync.sh)